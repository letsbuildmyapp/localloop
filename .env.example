# Public Firebase config (safe to expose to browser — they're public identifiers)
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=localloop-demo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=localloop-demo
VITE_FIREBASE_STORAGE_BUCKET=localloop-demo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Set to "true" to point at the local Firebase emulator suite
VITE_USE_EMULATORS=true

# Public Stripe key (publishable). Test mode.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# === Cloud Functions secrets — NEVER VITE_ prefix these ===
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# RESEND_API_KEY=re_replace_me
# LLM_API_KEY=sk-...
